{
  "name": "braze-sync",
  "version": "0.1.0",
  "description": "GitOps CLI for Braze — export, diff, and apply catalog schemas, content blocks, and custom attributes from Git",
  "type": "module",
  "bin": {
    "braze-sync": "./dist/index.js"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["braze", "gitops", "cli", "sync"],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "yaml": "^2.5.0"
  }
}
